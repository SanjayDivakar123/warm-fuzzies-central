# Jax / OutreachOS production environment variables
# Copy this file to your deployment secret manager or Vercel project settings.
# Values marked REQUIRED must exist for production to boot successfully.
# Values marked OPTIONAL are only needed for specific flows.

# -----------------------------------------------------------------------------
# Core app
# -----------------------------------------------------------------------------

# REQUIRED
# Public base URL for the production app, including https://
# Vercel Project Settings -> Domains or the default *.vercel.app URL
VERCEL_URL=https://your-jax-app.vercel.app

# REQUIRED
# Single admin password for Sanjay's protected admin area
# Generate a long random string with 1Password / Bitwarden / `openssl rand -base64 32`
ADMIN_PASSWORD=replace-with-a-long-random-password

# OPTIONAL
# Vercel provides PORT automatically at runtime; only set this for non-Vercel hosts
PORT=3000

# OPTIONAL
# Defaults to production automatically on Vercel
NODE_ENV=production

# -----------------------------------------------------------------------------
# Groq
# -----------------------------------------------------------------------------

# REQUIRED
# Groq API key used for Jax, scoring, follow-up writing, and reporting
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

# REQUIRED
# Supabase project URL
# Get from: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project.supabase.co

# REQUIRED
# Supabase service role JWT / service_role secret
# Get from: Supabase Dashboard -> Project Settings -> API
# Keep secret: never expose to the browser
SUPABASE_SERVICE_ROLE_JWT=your_supabase_service_role_jwt

# REQUIRED for browser dashboard queries
# Supabase publishable / anon key for frontend requests
# Get from: Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# REQUIRED for browser dashboard queries
# Usually the same as SUPABASE_URL, but exposed to Vite frontend
VITE_SUPABASE_URL=https://your-project.supabase.co

# OPTIONAL
# Database schema to target; leave as public unless you intentionally isolate schemas
SUPABASE_SCHEMA=public

# OPTIONAL
# Legacy compatibility variable if you still reference it elsewhere
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# OPTIONAL
# Legacy compatibility variable; not required by current runtime
SUPABASE_SECRET_KEY=your_supabase_secret_key

# -----------------------------------------------------------------------------
# Gmail OAuth + system delivery
# -----------------------------------------------------------------------------

# REQUIRED
# Google OAuth client ID for connected inboxes and system email sending
# Get from: Google Cloud Console -> APIs & Services -> Credentials
GMAIL_CLIENT_ID=your_google_oauth_client_id

# REQUIRED
# Google OAuth client secret paired with the client ID above
# Get from: Google Cloud Console -> APIs & Services -> Credentials
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret

# REQUIRED for onboarding emails, post-deploy alerts, and fallback sending
# JSON string containing OAuth tokens for the system Gmail account
# Store the full JSON as a single secret string
SYSTEM_GMAIL_CREDENTIALS={"access_token":"...","refresh_token":"...","scope":"https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.modify","token_type":"Bearer","expiry_date":0}

# OPTIONAL
# If you use Hunter or another external enrichment provider in production
HUNTER_API_KEY=your_optional_hunter_api_key

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------

# REQUIRED
# Stripe secret key used for checkout session creation and webhook verification
# Get from: Stripe Dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret

# REQUIRED
# Stripe webhook signing secret for /api/webhook/stripe
# Get from: Stripe Dashboard -> Developers -> Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# -----------------------------------------------------------------------------
# Vercel Blob / assets
# -----------------------------------------------------------------------------

# REQUIRED
# Token used to upload generated proposal PDFs to Vercel Blob
# Get from: Vercel Dashboard -> Storage -> Blob -> Tokens
BLOB_READ_WRITE_TOKEN=vercel_blob_token

# -----------------------------------------------------------------------------
# Scheduling / meeting handoff
# -----------------------------------------------------------------------------

# REQUIRED
# Calendly or Cal.com booking link used in meeting qualification emails
CALENDLY_URL=https://calendly.com/your-team/demo

# -----------------------------------------------------------------------------
# Frontend API configuration
# -----------------------------------------------------------------------------

# OPTIONAL
# Only set this if your frontend should call a different API origin than the same host
VITE_API_BASE_URL=

# OPTIONAL for local-only proxying, not normally used in production
VITE_API_PROXY_TARGET=

# -----------------------------------------------------------------------------
# CI/CD secrets for GitHub Actions -> Vercel deployment
# These are NOT read by the app at runtime, but are required in GitHub Actions.
# Store them as GitHub Actions repository secrets, not in Vercel.
# -----------------------------------------------------------------------------

# REQUIRED in GitHub Actions
# Create in Vercel account settings -> Tokens
VERCEL_TOKEN=your_vercel_token

# REQUIRED in GitHub Actions
# Found in `.vercel/project.json` after linking locally or in Vercel project metadata
VERCEL_PROJECT_ID=your_vercel_project_id

# REQUIRED in GitHub Actions
# Found in `.vercel/project.json` after linking locally or in Vercel account/team settings
VERCEL_ORG_ID=your_vercel_org_or_team_id
