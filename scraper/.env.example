# Environment Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/connor_outreach

# Redis
REDIS_URL=redis://localhost:6379/0

# Email Settings
DEFAULT_FROM_NAME=Connor Smith
REPLY_TO_EMAIL=connor@example.com

# Warm-up Schedule (emails per day for 14 days)
WARMUP_SCHEDULE=5,10,15,20,25,30,35,40,45,50,50,50,50,50

# Sequence Settings
SEQUENCE_STEPS=5
SEQUENCE_DELAYS_DAYS=0,3,7,7,7

# A/B Testing
AB_TEST_MIN_SAMPLES=100
AB_TEST_CONFIDENCE=0.95

# Scraping
GMB_RESULTS_PER_SEARCH=100
SCRAPING_DELAY_SECONDS=2.0

# Enrichment
ENRICHMENT_MAX_ATTEMPTS=3
ENRICHMENT_TIMEOUT_SECONDS=30

# Monitoring
HEALTH_CHECK_INTERVAL_MINUTES=60
REPLY_CHECK_INTERVAL_MINUTES=15

# Export
COLD_CALL_EXPORT_FORMAT=csv
