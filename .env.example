# Core app URL used in email links, OAuth callbacks, and onboarding redirects.
VERCEL_URL=http://localhost:5173

# Local API proxy target used by Vite to forward /api/* to the Express server.
VITE_API_PROXY_TARGET=http://localhost:3000

# Optional explicit frontend API base URL. Leave blank for local proxy usage.
VITE_API_BASE_URL=

# Port for the local Express API server.
PORT=3000

# Single admin password for the protected /admin dashboard.
ADMIN_PASSWORD=replace_with_a_long_random_password

# Groq API key used by Jax, copywriting, scoring, and reporting agents.
GROQ_API_KEY=gsk_replace_me

# Supabase project URL for server-side and browser-side clients.
SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SCHEMA=public

# Supabase publishable/anon key for browser access.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# Supabase service-role JWT for privileged server-side actions.
SUPABASE_SERVICE_ROLE_JWT=sb_service_role_replace_me

# Google OAuth credentials for connecting Gmail inboxes.
GMAIL_CLIENT_ID=replace_me.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=replace_me

# System Gmail OAuth token JSON used for platform-owned emails like onboarding.
SYSTEM_GMAIL_CREDENTIALS={"refresh_token":"replace_me","access_token":"replace_me","expiry_date":0,"token_type":"Bearer","scope":"https://www.googleapis.com/auth/gmail.send"}

# Stripe secret key used to create checkout sessions and verify webhook events.
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe webhook signing secret used by /api/webhook/stripe.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Vercel Blob token used to upload generated proposal PDFs.
BLOB_READ_WRITE_TOKEN=vercel_blob_replace_me

# Calendly link inserted into meeting-booking emails.
CALENDLY_URL=https://calendly.com/your-team/demo

# Optional Python binary for the external scraper bridge.
SCRAPER_PYTHON_BIN=python3
